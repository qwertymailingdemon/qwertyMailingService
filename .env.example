# Server Configuration
PORT=10000
NODE_ENV=production

# Security
# This is the key your clients must send in the 'x-api-key' header
SERVICE_API_KEY=your_super_secret_service_key_here

# Brevo Configuration
BREVO_API_KEY=xkeysib-your-brevo-api-key-here

# Default Sender (Must be verified in Brevo)
DEFAULT_SENDER_EMAIL=notifications@yourdomain.com
DEFAULT_SENDER_NAME=Mailing Agent Service